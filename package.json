{
  "name": "capybara-ai",
  "version": "0.0.0",
  "private": true,
  "description": "Enterprise security-first, self-hostable AI system",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp -r src/db/sql dist/db/sql",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate-cli.ts"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/csrf-protection": "7.1.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/multipart": "10.0.0",
    "@fastify/rate-limit": "10.3.0",
    "@node-rs/argon2": "2.0.2",
    "drizzle-orm": "0.45.2",
    "exceljs": "4.4.0",
    "fastify": "5.8.5",
    "jose": "6.2.3",
    "js-tiktoken": "1.0.21",
    "mammoth": "1.12.0",
    "openid-client": "6.8.4",
    "otpauth": "9.5.1",
    "pdf-parse": "2.4.5",
    "pdfkit": "0.18.0",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.1",
    "@types/node": "25.9.1",
    "@types/pdfkit": "0.17.6",
    "docx": "9.7.1",
    "drizzle-kit": "0.31.10",
    "pdf-lib": "1.17.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "overrides": {
    "esbuild": ">=0.25.0",
    "uuid": ">=11.1.1"
  }
}
