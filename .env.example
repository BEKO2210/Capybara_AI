# Capybara_AI — example environment.
# Copy to `.env` for local use. NEVER commit a real `.env`.
# Values here are documentation/placeholders ONLY — they are intentionally weak
# and are REJECTED by the production config validator (fail-closed).

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
# Authoritative environment switch: development | test | production.
# In `production`, the app REFUSES to start unless every required secret below
# is present and strong.
APP_ENV=development

# Informational only (APP_ENV is authoritative).
NODE_ENV=development

# HTTP bind. Defaults are loopback-only; expose deliberately behind a proxy.
APP_PORT=3000
APP_BIND=127.0.0.1

# Public base URL. REQUIRED in production (cookie/CSRF/CORS reasoning).
APP_BASE_URL=http://127.0.0.1:3000

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# DSN for the RESTRICTED application role (capybara_app: non-superuser, no
# BYPASSRLS). REQUIRED in production; TLS (sslmode=require) is enforced there.
DATABASE_URL=postgresql://capybara_app:CHANGE_ME@127.0.0.1:5432/capybara

# DSN for the PRIVILEGED migration role (creates the app role, applies RLS).
DATABASE_MIGRATION_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:5432/capybara

# Escape hatch to skip DB TLS enforcement. Refused in production.
# DB_ALLOW_INSECURE=false

# ----------------------------------------------------------------------------
# Secrets — REQUIRED & strength-validated in production.
# Generate strong values, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Must be >= 32 chars, high-entropy, and not a known placeholder.
# ----------------------------------------------------------------------------
COOKIE_SECRET=CHANGE_ME_generate_a_32_byte_random_value
SESSION_SECRET=CHANGE_ME_generate_a_32_byte_random_value

# Force-true in production; refused if set false there.
SECURE_COOKIES=true

# ----------------------------------------------------------------------------
# CORS — comma-separated origin allowlist. REQUIRED in production; "*" refused.
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# Logging: fatal | error | warn | info | debug | trace
# ----------------------------------------------------------------------------
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Rate limiting (global defaults; stricter limits applied per-route).
# ----------------------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Layered, identity-scoped limits (P2 hardening).
# LLM/completion calls per account per hour; uploads per org per hour;
# concurrent streaming responses per org; storage quota (MB) per org.
RATE_LIMIT_LLM_HOURLY=50
RATE_LIMIT_UPLOADS_HOURLY=20
RATE_LIMIT_STREAMS_PER_ORG=10
STORAGE_QUOTA_MB_PER_ORG=500

# Account brute-force lockout (P2 hardening). After LOGIN_MAX_FAILURES failures
# within LOGIN_FAILURE_WINDOW_MS the account locks for LOGIN_LOCK_BASE_MS,
# doubling on each successive lock up to LOGIN_LOCK_MAX_MS. Cleared on success
# or via the admin unlock endpoint (POST /api/admin/users/:id/unlock).
LOGIN_MAX_FAILURES=10
LOGIN_FAILURE_WINDOW_MS=900000
LOGIN_LOCK_BASE_MS=900000
LOGIN_LOCK_MAX_MS=86400000

# ----------------------------------------------------------------------------
# LLM providers — SERVER-ONLY endpoints. JSON array of provider definitions.
# Callers select a provider by `id`; they can NEVER supply a base URL (this is
# what closes the SSRF-via-base_url class of bug). Endpoints are trusted by
# virtue of being operator-configured here. Example (local Ollama + vLLM):
#   LLM_PROVIDERS=[{"id":"ollama","type":"openai-compatible","baseUrl":"http://127.0.0.1:11434","model":"llama3"}]
# Optional per-provider "apiKey" is supported for gated endpoints.
# ----------------------------------------------------------------------------
# LLM_PROVIDERS=[]
# LLM_DEFAULT_PROVIDER=ollama
LLM_REQUEST_TIMEOUT_MS=30000
# Provider "type" may be "openai-compatible" (Ollama/vLLM/OpenAI) or "anthropic".

# ----------------------------------------------------------------------------
# Encryption at rest — AES-256-GCM key for secrets such as TOTP/MFA secrets.
# 32 bytes, base64 OR hex. REQUIRED in production (ephemeral in dev if unset).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ----------------------------------------------------------------------------
ENCRYPTION_KEY=CHANGE_ME_generate_a_32_byte_base64_or_hex_key

# ----------------------------------------------------------------------------
# Master Key-Encryption-Key (KEK) — envelope encryption + key rotation.
# Wraps the per-org Data Encryption Keys (DEKs) in `encryption_key_versions`.
# 32 bytes, hex OR base64. REQUIRED in production (ephemeral in dev if unset).
# Rotate org keys via POST /api/admin/encryption/rotate (owner only).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ----------------------------------------------------------------------------
MASTER_KEK=CHANGE_ME_generate_a_32_byte_hex_or_base64_kek

# ----------------------------------------------------------------------------
# OIDC SSO (all-or-nothing — set all four or none). PKCE auth-code flow; the
# issuer must be HTTPS in production. SAML is stubbed (P2).
# ----------------------------------------------------------------------------
# OIDC_ISSUER=https://idp.example.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=https://app.example.com/auth/oidc/callback

# ----------------------------------------------------------------------------
# Document Intelligence (RAG)
# ----------------------------------------------------------------------------
# Master key for document/chunk encryption at rest (AES-256-GCM; per-tenant
# subkeys derived via HKDF). SEPARATE from ENCRYPTION_KEY. 32 bytes hex/base64.
# REQUIRED in production. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOCUMENT_ENCRYPTION_KEY=CHANGE_ME_separate_32_byte_hex_key

# Embeddings: local (Ollama) or openai. Endpoints are SERVER-ONLY.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=nomic-embed-text
# Required in production when EMBEDDING_PROVIDER=local:
# OLLAMA_BASE_URL=http://127.0.0.1:11434
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
# Required in production when EMBEDDING_PROVIDER=openai:
# OPENAI_API_KEY=sk-...

# Max upload size (MB) and encrypted-document storage directory.
MAX_UPLOAD_SIZE_MB=50
DOCUMENT_STORAGE_DIR=/data/documents

# Optional: if set, uploads are scanned via this ClamAV unix socket before
# storage (rejected if infected). If UNSET, scanning is skipped with a warning
# — see DEPLOYMENT_SECURITY.md. Strongly recommended for internet-facing use.
# CLAMAV_SOCKET=/var/run/clamav/clamd.ctl

# ----------------------------------------------------------------------------
# Enterprise integrations
# ----------------------------------------------------------------------------
# OpenAPI docs (Swagger UI at /api/docs). OFF by default; opt in explicitly.
# Keep disabled in production unless you intend to expose the API surface.
ENABLE_API_DOCS=false
# Outbound webhook delivery tuning.
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_RETRIES=3
