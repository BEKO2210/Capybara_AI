# Capybara_AI — example environment.
# Copy to `.env` for local use. NEVER commit a real `.env`.
# Values here are documentation/placeholders ONLY — they are intentionally weak
# and are REJECTED by the production config validator (fail-closed).

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
# Authoritative environment switch: development | test | production.
# In `production`, the app REFUSES to start unless every required secret below
# is present and strong.
APP_ENV=development

# Informational only (APP_ENV is authoritative).
NODE_ENV=development

# HTTP bind. Defaults are loopback-only; expose deliberately behind a proxy.
APP_PORT=3000
APP_BIND=127.0.0.1

# Public base URL. REQUIRED in production (cookie/CSRF/CORS reasoning).
APP_BASE_URL=http://127.0.0.1:3000

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# DSN for the RESTRICTED application role (capybara_app: non-superuser, no
# BYPASSRLS). REQUIRED in production; TLS (sslmode=require) is enforced there.
DATABASE_URL=postgresql://capybara_app:CHANGE_ME@127.0.0.1:5432/capybara

# DSN for the PRIVILEGED migration role (creates the app role, applies RLS).
DATABASE_MIGRATION_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:5432/capybara

# Escape hatch to skip DB TLS enforcement. Refused in production.
# DB_ALLOW_INSECURE=false

# ----------------------------------------------------------------------------
# Secrets — REQUIRED & strength-validated in production.
# Generate strong values, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Must be >= 32 chars, high-entropy, and not a known placeholder.
# ----------------------------------------------------------------------------
COOKIE_SECRET=CHANGE_ME_generate_a_32_byte_random_value
SESSION_SECRET=CHANGE_ME_generate_a_32_byte_random_value

# Force-true in production; refused if set false there.
SECURE_COOKIES=true

# ----------------------------------------------------------------------------
# CORS — comma-separated origin allowlist. REQUIRED in production; "*" refused.
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# Logging: fatal | error | warn | info | debug | trace
# ----------------------------------------------------------------------------
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Rate limiting (global defaults; stricter limits applied per-route).
# ----------------------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ----------------------------------------------------------------------------
# LLM providers — SERVER-ONLY endpoints. JSON array of provider definitions.
# Callers select a provider by `id`; they can NEVER supply a base URL (this is
# what closes the SSRF-via-base_url class of bug). Endpoints are trusted by
# virtue of being operator-configured here. Example (local Ollama + vLLM):
#   LLM_PROVIDERS=[{"id":"ollama","type":"openai-compatible","baseUrl":"http://127.0.0.1:11434","model":"llama3"}]
# Optional per-provider "apiKey" is supported for gated endpoints.
# ----------------------------------------------------------------------------
# LLM_PROVIDERS=[]
# LLM_DEFAULT_PROVIDER=ollama
LLM_REQUEST_TIMEOUT_MS=30000
# Provider "type" may be "openai-compatible" (Ollama/vLLM/OpenAI) or "anthropic".

# ----------------------------------------------------------------------------
# Encryption at rest — AES-256-GCM key for secrets such as TOTP/MFA secrets.
# 32 bytes, base64 OR hex. REQUIRED in production (ephemeral in dev if unset).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ----------------------------------------------------------------------------
ENCRYPTION_KEY=CHANGE_ME_generate_a_32_byte_base64_or_hex_key

# ----------------------------------------------------------------------------
# OIDC SSO (all-or-nothing — set all four or none). PKCE auth-code flow; the
# issuer must be HTTPS in production. SAML is stubbed (P2).
# ----------------------------------------------------------------------------
# OIDC_ISSUER=https://idp.example.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=https://app.example.com/auth/oidc/callback
